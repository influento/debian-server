# packages/base.list — Core system packages (installed via debootstrap + apt)
# Debootstrap installs a minimal system. These are the additional base packages.

# Kernel and firmware
linux-image-amd64
linux-headers-amd64
firmware-linux
firmware-iwlwifi

# CPU microcode (both included, only matching CPU loads at boot)
amd64-microcode
intel-microcode

# Essential system tools
build-essential
sudo
locales
network-manager
wpasupplicant
wireless-tools
rfkill
systemd-resolved
systemd-timesyncd

# Shell
zsh

# Editor — neovim installed via modules/neovim.sh (GitHub binary release)

# Filesystem tools
e2fsprogs
dosfstools

# Boot
efibootmgr
grub-efi-amd64

# Hardware detection
pciutils
usbutils

# Docs
man-db
manpages

# Misc essentials
git
curl
wget
less
unzip
tar
bash-completion
ca-certificates
gnupg
